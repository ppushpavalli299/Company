{
  "_version": "1.82.0",
  "sap.app": {
    "id": "project",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}"
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "project.view.AppUnified",
      "type": "XML",
      "id": "rootView",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.tnt": {},
        "sap.uxap": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "project.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.f.routing.Router",
        "viewType": "XML",
        "viewPath": "project.view",
        "controlId": "fcl",
        "controlAggregation": "beginColumnPages",
        "async": true
      },
      "routes": [
        {
          "name": "dashboard",
          "pattern": "",
          "target": [
            "Dashboard"
          ]
        },
        {
          "name": "company",
          "pattern": "company",
          "target": [
            "Company"
          ]
        },
        {
          "name": "company_detail",
          "pattern": "company/{id}/{layout}",
          "target": [
            "Company",
            "CompanyDetail"
          ]
        },
        {
          "name": "create_company",
          "pattern": "create_company",
          "target": [
            "Company",
            "CreateCompany"
          ]
        },
        {
          "name": "user",
          "pattern": "user",
          "target": [
            "User"
          ]
        },
        {
          "name": "userdetail",
          "pattern": "user/{id}/{layout}",
          "target": [
            "User",
            "UserDetail"
          ]
        },
        {
          "name": "create_user",
          "pattern": "create_user",
          "target": [
            "User",
            "CreateUser"
          ]
        }
      ],
      "targets": {
        "Dashboard": {
          "viewName": "Dashboard",
          "controlAggregation": "beginColumnPages"
        },
        "Company": {
          "viewPath": "project.company",
          "viewName": "Company",
          "controlAggregation": "beginColumnPages"
        },
        "CompanyDetail": {
          "viewPath": "project.company",
          "viewName": "CompanyDetail",
          "controlAggregation": "midColumnPages"
        },
        "CreateCompany": {
          "viewPath": "project.company",
          "viewName": "CreateCompany"
        },
        "User": {
          "viewPath": "project.user",
          "viewName": "User",
          "controlAggregation": "beginColumnPages"
        },
        "UserDetail": {
          "viewPath": "project.user",
          "viewName": "UserDetail",
          "controlAggregation": "midColumnPages"
        },
        "CreateUser": {
          "viewPath": "project.user",
          "viewName": "CreateUser"
        }
      }
    }
  }
}